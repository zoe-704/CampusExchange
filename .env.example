# Copy this file to .env and fill in your Supabase project's values.
# Local dev: run `supabase start` and use the "API URL" / "anon key" it prints.
# Hosted project: Project Settings > API in the Supabase dashboard.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used only by the Playwright e2e suite (tests/e2e/), never by the app
# itself. Point these at two dedicated, already-confirmed test accounts —
# the suite logs in with them, it doesn't sign them up. Two accounts are
# required so ownership/RLS tests can act as "the owner" (A) and "someone
# else" (B) against the same data. Create them via the Supabase dashboard
# (Authentication > Users > Add user, with "Auto Confirm User" checked)
# or the Admin API.
E2E_TEST_USER_A_EMAIL=
E2E_TEST_USER_A_PASSWORD=
E2E_TEST_USER_B_EMAIL=
E2E_TEST_USER_B_PASSWORD=
E2E_TEST_USER_C_EMAIL=
E2E_TEST_USER_C_PASSWORD=
