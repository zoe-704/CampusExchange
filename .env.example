# Copy this file to .env and fill in your Supabase project's values.
# Local dev: run `supabase start` and use the "API URL" / "anon key" it prints.
# Hosted project: Project Settings > API in the Supabase dashboard.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used only by the Playwright e2e suite (tests/e2e/), never by the app
# itself. Point this at a dedicated test account that already exists and
# is email-confirmed — the suite logs in with it, it doesn't sign it up.
# Create one via the Supabase dashboard (Authentication > Users > Add
# user, with "Auto Confirm User" checked) or the Admin API.
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=
